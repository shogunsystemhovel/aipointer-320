# AIPointer .gitignore
# Last reviewed 2026-05-13 pre v1.0 public release

# ----------------------------------------------------------------------
# Dependencies
# ----------------------------------------------------------------------
node_modules/
.npm/
.yarn/
.pnpm-store/
jspm_packages/

# ----------------------------------------------------------------------
# Build outputs
# ----------------------------------------------------------------------
dist/
dist-electron/
out/
build/Release/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/
.vite/
*.tsbuildinfo
vite.config.ts.timestamp-*
vite.config.js.timestamp-*

# ----------------------------------------------------------------------
# Electron-builder outputs
# ----------------------------------------------------------------------
release/
release-artifacts/
metadata-root/
metadata-updates/
UPLOAD-CHECKLIST.txt

# Built installers and packages
*.dmg
*.pkg
*.exe
*.msi
*.AppImage
*.deb
*.rpm
*.snap
*.tar.gz
*.zip

# Built app bundles
*.app/
mac/
mac-arm64/
mac-arm64-zip/
mac-zip/
win-unpacked/
win-ia32-unpacked/
linux-unpacked/

# electron-builder generated metadata (built at release time, not committed)
latest.yml
latest-mac.yml
latest-linux.yml
beta.yml
alpha.yml

# Native modules (built per-platform, not committed)
*.node
*.dll
*.dylib
*.so

# ----------------------------------------------------------------------
# Secrets and credentials (CRITICAL, never commit)
# ----------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template

# Apple signing
*.p12
*.cer
*.pem
*.key
*.mobileprovision
*.provisionprofile
api_key.p8
apple_app_specific_password*
notarize.json
notarize.plist

# Windows signing
*.pfx
*.spc

# Anything that might hold an API key
**/secrets.json
**/secrets.local.*
**/credentials.json

# ----------------------------------------------------------------------
# Logs
# ----------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----------------------------------------------------------------------
# Testing and coverage
# ----------------------------------------------------------------------
coverage/
.nyc_output/
junit.xml
test-results/
playwright-report/
playwright/.cache/

# ----------------------------------------------------------------------
# Local databases and dumps
# ----------------------------------------------------------------------
*.sqlite
*.sqlite-journal
*.db
*.dump

# ----------------------------------------------------------------------
# Temporary files
# ----------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~

# Screenshot dev scratch
/tmp/aipointer-test.*

# Quarantined corrupted configs (only if accidentally copied from user data)
config.json.corrupted-*

# ----------------------------------------------------------------------
# OS files
# ----------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?
.fseventsd
.DocumentRevisions-V100
.TemporaryItems
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*
.nfs*

# ----------------------------------------------------------------------
# Editor and IDE
# ----------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.vscode-test/

.idea/
*.iml
*.ipr
*.iws

*.sublime-project
*.sublime-workspace

.zed/

# ----------------------------------------------------------------------
# Landing page sub-folder
# ----------------------------------------------------------------------
# landingpage/ stays in the repo as marketing site source.
# But anything inside that's a build artifact should be excluded:
landingpage/node_modules/
landingpage/.vite/
landingpage/dist/

# ----------------------------------------------------------------------
# Landing page large media (hosted on aipointer.app, not in repo)
# ----------------------------------------------------------------------
landingpage/AIPointer/
landingpage/assets/video/*.mp4
landingpage/assets/video/*.webm
landingpage/assets/img/*.gif
docs/
landingpage/
electron-builder.local.yml
scripts/
